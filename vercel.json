{
  "rewrites": [
    { "source": "/street-team-marketing-agency", "destination": "/street-team-marketing-agency.html" },
    { "source": "/brand-ambassador-agency", "destination": "/brand-ambassador-agency.html" },
    { "source": "/guerrilla-marketing-agency", "destination": "/guerrilla-marketing-agency.html" },
    { "source": "/product-sampling-agency", "destination": "/product-sampling-agency.html" },
    { "source": "/experiential-marketing-agency", "destination": "/experiential-marketing-agency.html" },
    { "source": "/field-marketing-agency", "destination": "/field-marketing-agency.html" },
    { "source": "/trade-show-staffing-agency", "destination": "/trade-show-staffing-agency.html" },
    { "source": "/promotional-staffing-agency", "destination": "/promotional-staffing-agency.html" },
    { "source": "/event-marketing-agency", "destination": "/event-marketing-agency.html" },
    { "source": "/mobile-marketing-tours", "destination": "/mobile-marketing-tours.html" },
    { "source": "/brand-activation-agency", "destination": "/brand-activation-agency.html" },
    { "source": "/corporate-event-staffing", "destination": "/corporate-event-staffing.html" },
    { "source": "/college-marketing-agency", "destination": "/college-marketing-agency.html" },
    { "source": "/festival-staffing-agency", "destination": "/festival-staffing-agency.html" },
    { "source": "/fifa-world-cup-2026-staffing", "destination": "/fifa-world-cup-2026-staffing.html" },
    { "source": "/fifa-world-cup-2026-staffing/:city", "destination": "/fifa-world-cup-2026-staffing/:city.html" },
    { "source": "/locations/:state/:city/:service", "destination": "/locations/:state/:city/:service.html" },
    { "source": "/case-studies/", "destination": "/case-studies/index.html" },
    { "source": "/case-studies/:slug", "destination": "/case-studies/:slug.html" },
    { "source": "/compare/:slug", "destination": "/compare/:slug.html" },
    { "source": "/what-is-street-team-marketing", "destination": "/what-is-street-team-marketing.html" },
    { "source": "/how-it-works", "destination": "/how-it-works.html" },
    { "source": "/about-street-teams-co", "destination": "/about-street-teams-co.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
